# OctoFit Tracker - Frontend Environment Variables
# Copy this file to .env.local and update the VITE_CODESPACE_NAME

# GitHub Codespaces Name - Required for Codespaces deployment
# Example: improved-space-barnacle-r7545grg7q6355g9
# If not set, the app will fall back to http://localhost:8000
VITE_CODESPACE_NAME=your-codespace-name

# Note: To run locally, either:
# 1. Set VITE_CODESPACE_NAME to your actual Codespaces name, or
# 2. Leave it unset to use http://localhost:8000
